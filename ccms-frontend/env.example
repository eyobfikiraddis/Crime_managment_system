# Server-side base URL for CCMS backend API
CCMS_API_BASE_URL="https://api.example.com"

# Secret used to sign sessions (min 32 chars). Provide either NEXTAUTH_SECRET or SESSION_SECRET.
NEXTAUTH_SECRET="replace-with-32-char-secret"
SESSION_SECRET="replace-with-32-char-secret"

# Next.js runtime environment
NODE_ENV="development"

# Public API URL for browser requests
NEXT_PUBLIC_API_URL="https://api.example.com"

# Cloudinary cloud name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# App version string
NEXT_PUBLIC_APP_VERSION="0.1.0"

# Environment name for display
NEXT_PUBLIC_ENV="local"
