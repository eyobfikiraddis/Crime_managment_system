# Auth
SECRET_KEY=change-this-secret-key-32-chars-min-1234567890
SECRET_KEY_ID=k1
PREVIOUS_SECRET_KEYS=[]

# Hashing
BCRYPT_ROUNDS=12

# Session & Token Lifetimes
ACCESS_TOKEN_TTL_SECONDS=900
MAX_SESSION_SECONDS=28800
IDLE_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_SESSIONS_PER_OFFICER=1
REQUEST_SIZE_LIMIT_BYTES=2097152
PERMISSION_CACHE_TTL_SECONDS=300

# Redis
REDIS_URL=redis://redis:6379/0

# Database
DATABASE_URL=postgresql+asyncpg://ccms_user:ccms_secure_password@postgres:5432/ccms

# CORS
CORS_ALLOWED_ORIGINS=https://ccms.internal,https://admin.ccms.internal

# Feature Flags
AUTO_CLOSE_ON_VERDICT=true

# Object Storage
OBJECT_STORAGE_ENDPOINT=https://minio.internal
OBJECT_STORAGE_BUCKET=ccms-evidence

# Application
APP_ENV=development
APP_VERSION=3.0.0
DEBUG=false
LOG_LEVEL=INFO
